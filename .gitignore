node_modules/
dist/
.astro/
.DS_Store
.env
.env.*
!.env.example

# crawl artefacts (kept locally for re-runs but not committed — too large)
content-source/raw/
content-source/crawl-tmp/
Squarespace-Wordpress-Export-*.xml

# local design / debug screenshots (kept out of repo — large binaries)
design/screenshots/

# Generated by scripts/optimize-images.mjs as a prebuild step.
# CI regenerates idempotently in ~15s; keeping the repo small.
public/media/*.webp
public/media/*.avif

# editor
.vscode/
.idea/
*.swp

# Claude Code runtime state (lock files, per-user local settings).
# Project-shared `.claude/settings.json` SHOULD be committed when added.
.claude/scheduled_tasks.lock
.claude/settings.local.json
