---
import { ClientRouter } from 'astro:transitions';
import { SEO } from 'astro-seo';
import '~/styles/global.css';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
import AnnouncementBar from '~/components/AnnouncementBar.astro';
import { website, org } from '~/lib/seo';
import type { JsonLd } from '~/lib/seo';
import { link, absoluteUrl } from '~/lib/link';

interface Props {
  title: string;
  description?: string;
  bg?: 'white' | 'myth';
  bodyClass?: string;
  /** Page-specific structured data — appended after the global WebSite + Organization graph. */
  jsonLd?: JsonLd | JsonLd[];
  /** OG image absolute or site-relative URL. */
  ogImage?: string;
  /** Set to true on long-form article pages so OG type is "article". */
  article?: boolean;
  /** Site-relative path of the LCP image to <link rel="preload"> for CWV. */
  preloadImage?: string;
}

const {
  title,
  description = 'Rethink Aadhaar — Opt-out from Aadhaar. Take action now.',
  bg = 'white',
  bodyClass = '',
  jsonLd,
  ogImage = '/og-default.png',
  article = false,
  preloadImage,
} = Astro.props;

const fullTitle =
  title === 'Rethink Aadhaar'
    ? 'Rethink Aadhaar — Opt-out from Aadhaar. Take action now.'
    : `${title} — Rethink Aadhaar`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageAbs = ogImage.startsWith('http') ? ogImage : absoluteUrl(ogImage, Astro.site!);

// Always emit WebSite + Organization on every page; append page-specific graph.
const blocks: JsonLd[] = [website(), org(), ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="en-IN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F7F2E8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0E0E10" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/x-icon" href={link('/favicon.ico')} />
    <link rel="apple-touch-icon" sizes="180x180" href={link('/apple-touch-icon.png')} />
    {preloadImage && (() => {
      // Prefer AVIF for the LCP preload, then WebP, then the original. The
      // browser uses the first <link> whose `type` it supports.
      const avif = preloadImage.replace(/\.(jpe?g|png)$/i, '.avif');
      const webp = preloadImage.replace(/\.(jpe?g|png)$/i, '.webp');
      return (
        <>
          {avif !== preloadImage && (
            <link rel="preload" as="image" href={link(avif)} type="image/avif" fetchpriority="high" />
          )}
          {webp !== preloadImage && (
            <link rel="preload" as="image" href={link(webp)} type="image/webp" fetchpriority="high" />
          )}
          <link rel="preload" as="image" href={link(preloadImage)} fetchpriority="high" />
        </>
      );
    })()}
    <link rel="alternate" type="application/rss+xml" title="Rethink Aadhaar — Updates" href={link('/rss.xml')} />
    <link rel="alternate" type="text/plain" title="LLM-readable index" href={link('/llms.txt')} />
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: { title: fullTitle, type: article ? 'article' : 'website', image: ogImageAbs },
        optional: { siteName: 'Rethink Aadhaar', description },
      }}
      twitter={{ card: 'summary_large_image', site: '@no2uid', creator: '@no2uid' }}
    />
    {blocks.map((block) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
    <script is:inline>
      // Light is the default. Dark mode is opt-in via the toggle and persisted
      // in localStorage. We deliberately do NOT auto-pick dark from OS pref —
      // brand parity with rethinkaadhaar.in (cream paper) wins over OS theme.
      //
      // Runs synchronously before first paint to avoid a light-mode flash on
      // dark-preferred reloads. The `astro:after-swap` listener below re-syncs
      // the class on every view transition so the toggle state always matches
      // localStorage even after navigation.
      (function () {
        function sync() {
          try {
            var dark = localStorage.getItem('theme') === 'dark';
            document.documentElement.classList.toggle('dark', dark);
          } catch (e) {}
        }
        sync();
        document.addEventListener('astro:after-swap', sync);
      })();
    </script>
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class={`min-h-screen ${bg === 'myth' ? 'bg-myth' : 'bg-bg'} ${bodyClass}`}>
    <a href="#main" class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:left-4 focus-visible:top-4 focus-visible:z-50 focus-visible:bg-button focus-visible:text-white focus-visible:px-4 focus-visible:py-2">Skip to content</a>
    <AnnouncementBar />
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <script is:inline>
      // Lazy-load Twitter widgets.js the first time a `.twitter-tweet`
      // approaches the viewport. Pages with no tweets pay nothing; pages
      // with tweets load the script exactly once even if there are many
      // embeds. View-transitions re-run this on every `astro:page-load`
      // since the observer state doesn't survive a swap.
      (function () {
        function init() {
          var nodes = document.querySelectorAll('.twitter-tweet');
          if (!nodes.length) return;
          // Already loaded? Nudge widgets to re-scan after a transition.
          if (window.twttr && window.twttr.widgets) {
            window.twttr.widgets.load();
            return;
          }
          if (document.querySelector('script[data-twttr-loader]')) return;
          var io = new IntersectionObserver(function (entries, obs) {
            for (var i = 0; i < entries.length; i++) {
              if (!entries[i].isIntersecting) continue;
              obs.disconnect();
              var s = document.createElement('script');
              s.src = 'https://platform.twitter.com/widgets.js';
              s.async = true;
              s.charset = 'utf-8';
              s.setAttribute('data-twttr-loader', '1');
              document.body.appendChild(s);
              return;
            }
          }, { rootMargin: '400px 0px' });
          for (var j = 0; j < nodes.length; j++) io.observe(nodes[j]);
        }
        init();
        document.addEventListener('astro:page-load', init);
      })();
    </script>
  </body>
</html>
