---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import { byDateDesc, entryHref, notDraft } from '~/lib/entries';
import { itemList } from '~/lib/seo';
import { formatDate } from '~/lib/format';

const stories = (await getCollection('exclusion')).filter(notDraft).sort(byDateDesc);
const description = 'Stories from the ground: what Aadhaar exclusion looks like in practice.';

// Render each entry's full body inline so videos and prose show as a feed,
// matching the upstream Squarespace presentation rather than a stripped list.
const rendered = await Promise.all(
  stories.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const grouped = new Map<number, typeof rendered>();
for (const r of rendered) {
  const y = r.entry.data.date.getUTCFullYear();
  if (!grouped.has(y)) grouped.set(y, []);
  grouped.get(y)!.push(r);
}
const years = [...grouped.keys()].sort((a, b) => b - a);
const firstYear = years[years.length - 1];

const jsonLd = itemList({
  name: 'Exclusion stories',
  url: '/testimonials',
  items: stories.slice(0, 25).map((s) => ({
    name: s.data.title,
    url: entryHref('exclusion', s),
    description: s.data.summary,
  })),
});
---

<BaseLayout title="Exclusion" description={description} jsonLd={jsonLd}>
  <HeroTitle eyebrow="Stories from the ground">Exclusion</HeroTitle>

  <p class="container-prose mt-6 text-lg md:text-xl text-ink/80 font-body text-pretty fade-up">
    Aadhaar promised inclusion. The lived reality has been exclusion — from rations and pensions, from school admissions and bank accounts, from medical treatment and voting rolls. These are some of the documented cases.
  </p>

  <p class="container-prose mt-8 caps text-xs text-ink/55 tracking-[0.18em] fade-up delay-1">
    Documented from {firstYear} · ongoing
  </p>

  {years.map((year) => (
    <section class="container-prose mt-16 md:mt-20 fade-up">
      <header class="mb-8">
        <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight">{year}</h2>
      </header>

      <div class="space-y-16">
        {grouped.get(year)!.map(({ entry, Content }) => {
          const detail = entryHref('exclusion', entry);
          return (
            <article class="border-t border-ink/10 pt-8">
              <header class="mb-5">
                <p class="caps text-xs text-ink/55 mb-2">
                  {formatDate(entry.data.date, 'medium')}{entry.data.location ? ` · ${entry.data.location}` : ''}
                </p>
                <h3 class="font-display text-xl md:text-2xl font-extrabold tracking-tight leading-snug text-balance">
                  <a href={detail} class="hover:text-accent transition-colors">{entry.data.title}</a>
                </h3>
              </header>
              <div class="prose dark:prose-invert font-body text-pretty max-w-none">
                <Content />
              </div>
              <p class="mt-5">
                <a class="caps text-xs text-accent hover:underline" href={detail}>Permalink →</a>
              </p>
            </article>
          );
        })}
      </div>
    </section>
  ))}

  <div class="mb-24"></div>
</BaseLayout>
