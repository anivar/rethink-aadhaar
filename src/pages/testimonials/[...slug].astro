---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import ShareRow from '~/components/ShareRow.astro';
import StickyAction from '~/components/StickyAction.astro';
import { entryHref, notDraft } from '~/lib/entries';
import { formatDate } from '~/lib/format';
import { article, breadcrumb, MENTIONS, place } from '~/lib/seo';
import { link } from '~/lib/link';

export async function getStaticPaths() {
  const items = (await getCollection('exclusion')).filter(notDraft);
  return items.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const href = entryHref('exclusion', entry);
const dateStr = formatDate(entry.data.date, 'long');

const jsonLd = [
  article({
    type: 'ReportageNewsArticle',
    url: new URL(href, Astro.site).toString(),
    title: entry.data.title,
    description: entry.data.summary,
    datePublished: entry.data.date,
    image: entry.data.shareImage,
    section: 'Exclusion',
    mentions: MENTIONS,
    contentLocation: entry.data.location ? place(entry.data.location) : undefined,
  }),
  breadcrumb([
    { name: 'Home', url: '/' },
    { name: 'Exclusion', url: '/testimonials' },
    { name: entry.data.title, url: href },
  ]),
];
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogImage={entry.data.shareImage} article jsonLd={jsonLd}>
  <HeroTitle eyebrow={`Exclusion · ${dateStr}${entry.data.location ? ' · ' + entry.data.location : ''}`}>
    {entry.data.title}
  </HeroTitle>

  <article class="container-prose mt-10 prose dark:prose-invert font-body text-pretty fade-up">
    <Content />
  </article>

  <div class="container-prose">
    <ShareRow title={entry.data.title} />
    <p class="mt-12 mb-12"><a class="caps text-xs text-accent" href={link('/testimonials')}>← Back to Exclusion</a></p>
  </div>

  <StickyAction />
</BaseLayout>
