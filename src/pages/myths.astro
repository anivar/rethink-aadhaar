---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import MythCard from '~/components/MythCard.astro';
import { byOrder } from '~/lib/entries';
import { itemList, claimReview } from '~/lib/seo';
import { link } from '~/lib/link';
import { mythSlug } from '~/lib/myth-slug';

const myths = (await getCollection('myth')).sort(byOrder);
const rendered = await Promise.all(myths.map(async (m) => ({ ...m, ...(await render(m)) })));

const mythsUrl = new URL('/myths', Astro.site).toString();
const jsonLd = [
  itemList({
    name: 'Myths about Aadhaar',
    url: '/myths',
    items: myths.map((m) => ({
      name: m.data.myth,
      url: `/myths/${mythSlug(m.data.myth)}`,
      description: m.data.fact,
    })),
  }),
  // One ClaimReview per myth — eligible for Google fact-check rich
  // results and read by answer engines as an authoritative verdict.
  ...myths.map((m) =>
    claimReview({
      url: mythsUrl,
      claim: m.data.myth,
      verdict: m.data.fact ?? 'See full evidence on this page.',
    }),
  ),
];
---

<BaseLayout title="Myths" description="Common myths about Aadhaar, and the facts behind them." jsonLd={jsonLd}>
  <HeroTitle eyebrow="Common claims, examined">Myths</HeroTitle>

  <p class="container-prose mt-6 text-lg md:text-xl text-ink/80 font-body text-pretty fade-up">
    Claims about Aadhaar that are often repeated in policy circles and in the press — and what the evidence actually shows.
  </p>

  {/* Quick jump on desktop — scannable index of every myth. */}
  {rendered.length > 1 && (
    <nav class="container-prose mt-8 hidden md:block fade-up delay-1" aria-label="Jump to a myth">
      <ul class="grid grid-cols-2 gap-x-6 gap-y-1.5">
        {rendered.map((m, i) => (
          <li>
            <a
              href={link(`/myths/${mythSlug(m.data.myth)}/`)}
              class="group flex items-baseline gap-3 py-1.5 text-sm text-ink/70 hover:text-accent transition-colors"
            >
              <span class="caps text-[0.7rem] text-accent w-6 shrink-0 tracking-[0.08em]">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-pretty leading-snug">{m.data.myth}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <section class="container-prose mt-10 md:mt-14 mb-24">
    {rendered.map((m, i) => (
      <MythCard
        myth={m.data.myth}
        fact={m.data.fact}
        index={i + 1}
        href={link(`/myths/${mythSlug(m.data.myth)}/`)}
        summary
      >
        <m.Content />
      </MythCard>
    ))}
  </section>
</BaseLayout>

<style is:global>
  /* Summary mode on /myths listing: show only the first paragraph from the
     source body (the natural break point), hide everything after it. The
     full content lives on /myths/<slug>/. Targets the prose container's
     direct children — first child stays, all subsequent siblings hide. */
  .myth-summary > * + * { display: none; }
</style>
