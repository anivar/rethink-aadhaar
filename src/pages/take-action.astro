---
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { breadcrumb } from '~/lib/seo';
import { link } from '~/lib/link';

const page = await getEntry('page', 'take-action');
const { Content } = await render(page!);
const jsonLd = breadcrumb([
  { name: 'Home', url: '/' },
  { name: 'Take action', url: '/take-action' },
]);
---

<BaseLayout title="Take action" description="Sign on, opt out, launch a local campaign — concrete ways to push back against coercive Aadhaar mandates." jsonLd={jsonLd}>
  <header class="container-prose pt-12 md:pt-20">
    <div class="grid md:grid-cols-[1fr_auto] items-end gap-6 fade-up">
      <div>
        <p class="eyebrow mb-4">What can I do? What can't we do?</p>
        <h1 class="hero-title text-balance text-left">Take action</h1>
      </div>
      <img
        src={link('/media/1501143464367-72QK8G9CYTG48Q7A6Y2O-noun_1067645.png')}
        alt="Fist with network nodes"
        class="w-24 sm:w-28 md:w-40 dark:invert justify-self-end"
        loading="eager"
        width="160"
        height="160"
      />
    </div>
  </header>

  <article class="container-prose mt-10 md:mt-14 prose dark:prose-invert font-body text-pretty fade-up actions-list">
    <Content />
  </article>

  <section class="container-prose mt-16 md:mt-20 mb-24 hairline pt-10 md:pt-14 fade-up">
    <p class="eyebrow mb-3">Stay in the loop</p>
    <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight mb-4">Subscribe to the mailing list</h2>
    <p class="text-base md:text-lg text-ink/75 font-body text-pretty mb-6 max-w-2xl">
      We use Riseup for the list — you'll get a confirmation email after signing up. Unsubscribe any time.
    </p>
    <form
      action="https://lists.riseup.net/www/subscribe/rethink-aadhaar"
      method="post"
      class="grid sm:grid-cols-[1fr_auto] gap-3 max-w-xl"
    >
      <label class="sr-only" for="ta-email">Email address</label>
      <input
        id="ta-email"
        name="email"
        type="email"
        autocomplete="email"
        required
        placeholder="your-email@example.com"
        class="font-body text-base px-4 py-4 border border-ink/30 bg-bg text-ink focus:border-accent outline-none w-full"
      />
      <button type="submit" class="btn-dark whitespace-nowrap">Sign up</button>
    </form>
  </section>
</BaseLayout>

<style is:global>
  /* Numbered actions, rule-separated. Each ### in the markdown becomes a
     row with a big red counter and a hairline above. No card backgrounds
     or :has() — keeps the layout robust across browsers and avoids the
     sibling-selector overrides that broke the v1 design. */
  .actions-list {
    counter-reset: action;
    max-width: none;
  }
  .actions-list > p:first-of-type {
    font-size: 1.125rem;
    color: rgb(var(--ink) / 0.78);
    margin-bottom: 2.5rem !important;
  }
  .actions-list h3 {
    counter-increment: action;
    /* Grid (not flex) — flex items keep `min-width: auto` and refuse to wrap
       long heading text on narrow viewports, leaving the title to overflow
       past the screen edge. The `auto 1fr` track lets the title column
       collapse to the remaining width and wrap normally. */
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: baseline;
    gap: 1rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.55rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
    border-top: 1px solid rgb(var(--ink) / 0.18);
    padding-top: 2rem;
    margin: 2.75rem 0 1rem !important;
  }
  .actions-list h3:first-of-type {
    border-top-width: 2px;
    border-top-color: rgb(var(--ink));
    margin-top: 0 !important;
  }
  .actions-list h3::before {
    content: counter(action, decimal-leading-zero);
    color: #D7282F;
    font-weight: 800;
    font-size: 2rem;
    line-height: 1;
    width: 2.75rem;
    letter-spacing: -0.04em;
    align-self: start;
  }
  /* Bump body paragraph readability inside each action — current default is
     fine for the hero but the dense action prose needs more line-height. */
  .actions-list h3 ~ p {
    font-size: 1.0625rem;
    line-height: 1.6;
  }
  /* CTA-style "→" links inside each action paragraph. Pill-button look so
     each section terminates in a clear call-to-action rather than another
     line of body text. */
  .actions-list h3 ~ p > a:first-child:last-child,
  .actions-list h3 + p > a {
    display: inline-block;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    color: #D7282F;
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
    padding: 0.35rem 0;
  }
  .actions-list h3 ~ p > a:hover { color: #A41C28; }

  @media (min-width: 768px) {
    .actions-list h3 {
      font-size: 2rem;
      padding-top: 2.5rem;
      margin-top: 3.25rem !important;
      gap: 1.4rem;
    }
    .actions-list h3::before { font-size: 2.75rem; width: 4rem; }
    .actions-list h3 ~ p { font-size: 1.125rem; }
  }
</style>
