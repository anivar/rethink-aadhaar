---
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import { breadcrumb } from '~/lib/seo';

const page = await getEntry('page', 'about');
const { Content } = await render(page!);
const jsonLd = breadcrumb([{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]);
---

<BaseLayout title="About" description="A non-partisan campaign concerned about India's Unique Identification (UID) or Aadhaar project." jsonLd={jsonLd}>
  <HeroTitle eyebrow="A non-partisan campaign">About</HeroTitle>

  <article class="container-prose mt-10 mb-24 prose dark:prose-invert font-body text-pretty fade-up">
    <Content />
  </article>
</BaseLayout>
