---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import FAQItem from '~/components/FAQItem.astro';
import { byOrder } from '~/lib/entries';
import { faqPage } from '~/lib/seo';

const faqs = (await getCollection('faq')).sort(byOrder);
const rendered = await Promise.all(faqs.map(async (f) => ({ ...f, ...(await render(f)) })));

// Build FAQPage JSON-LD from the short answer (or first 280 chars of body if no short).
const jsonLd = faqPage(
  faqs.map((f) => ({
    question: f.data.question,
    answer: f.data.short ?? f.body?.replace(/\s+/g, ' ').trim().slice(0, 280) ?? '',
  })),
);
---

<BaseLayout title="FAQs" description="Common questions about Aadhaar, privacy, welfare, and the Indian context." jsonLd={jsonLd}>
  <HeroTitle eyebrow="Common questions">FAQs</HeroTitle>

  <p class="container-prose mt-6 text-lg md:text-xl text-ink/80 font-body text-pretty fade-up">
    Short answers to the questions we hear most often — from privacy and surveillance to welfare exclusion and how Aadhaar compares to other identity systems.
  </p>

  {rendered.length > 1 && (
    <nav class="container-prose mt-8 fade-up delay-1" aria-label="Jump to a question">
      <ul class="flex flex-wrap gap-2">
        {rendered.map((f, i) => (
          <li>
            <a
              href={`#faq-${i + 1}`}
              class="caps text-[0.7rem] tracking-[0.08em] inline-block px-3 py-2 border border-ink/20 hover:border-accent hover:text-accent transition-colors"
            >
              Q{String(i + 1).padStart(2, '0')}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <section class="container-prose mt-10 md:mt-14 mb-24">
    {rendered.map((f, i) => (
      <FAQItem question={f.data.question} short={f.data.short} index={i + 1}>
        <f.Content />
      </FAQItem>
    ))}
  </section>
</BaseLayout>
