---
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import { breadcrumb, event } from '~/lib/seo';
import { link } from '~/lib/link';

const page = await getEntry('page', 'campaign2025');
const { Content } = await render(page!);
const jsonLd = [
  event({
    name: 'Beware of Aadhaar — Campaign 2025 launch',
    url: '/campaign2025',
    startDate: '2025-12-10',
    description:
      'Collective statement endorsed by 50+ Indian organisations and many individual signatories, released on Human Rights Day 2025 by the Rethink Aadhaar campaign.',
  }),
  breadcrumb([
    { name: 'Home', url: '/' },
    { name: 'Campaign 2025', url: '/campaign2025' },
  ]),
];
---

<BaseLayout title="Campaign 2025" description="Beware of Aadhaar — a collective statement endorsed by 50+ Indian organisations and many individual signatories, released on Human Rights Day 2025." article jsonLd={jsonLd}>
  <HeroTitle eyebrow="Released 10 December 2025 · Human Rights Day">Campaign 2025</HeroTitle>

  {/* Identity / context strip — endorsements and signatory framing without
      hard-coding a count (the canonical list lives in the markdown body). */}
  <div class="container-prose mt-8 fade-up delay-1">
    <div class="surface-paper px-6 md:px-8 py-6 md:py-7 grid sm:grid-cols-3 gap-4 sm:gap-6 text-center sm:text-left">
      <div>
        <p class="caps text-[0.7rem] text-ink/55 tracking-[0.12em] mb-1">Title</p>
        <p class="font-display font-bold text-base md:text-lg leading-snug text-balance">Beware of Aadhaar</p>
      </div>
      <div>
        <p class="caps text-[0.7rem] text-ink/55 tracking-[0.12em] mb-1">Endorsed by</p>
        <p class="font-display font-bold text-base md:text-lg leading-snug text-balance">50+ Indian organisations &amp; many individuals</p>
      </div>
      <div>
        <p class="caps text-[0.7rem] text-ink/55 tracking-[0.12em] mb-1">Released</p>
        <p class="font-display font-bold text-base md:text-lg leading-snug">10 Dec 2025</p>
      </div>
    </div>
  </div>

  <article class="container-prose mt-12 md:mt-16 mb-24 prose dark:prose-invert font-body text-pretty fade-up campaign-prose">
    <Content />
  </article>

  <div class="container-prose mb-24 -mt-12 flex flex-wrap gap-3 fade-up">
    <a href={link('/take-action')} class="btn-dark">Take action</a>
    <a href={link('/resources')} class="btn-outline">Resources</a>
  </div>
</BaseLayout>

<style is:global>
  /* Number the eleven concerns inside the campaign body. The markdown
     uses a 1.-style ordered list; we render each item as a card-like row
     with a large red counter, mirrored to the myths/take-action language. */
  .campaign-prose ol {
    counter-reset: concern;
    list-style: none;
    padding-left: 0;
    margin-top: 1.5rem;
  }
  .campaign-prose ol > li {
    counter-increment: concern;
    position: relative;
    padding: 1.25rem 0 1.25rem 3.5rem;
    border-top: 1px solid rgb(var(--ink) / 0.12);
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
  .campaign-prose ol > li:first-child { border-top-width: 2px; border-top-color: rgb(var(--ink)); }
  .campaign-prose ol > li::before {
    content: counter(concern, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 1.1rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: #D7282F;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) {
    .campaign-prose ol > li { padding-left: 4.5rem; padding-top: 1.5rem; padding-bottom: 1.5rem; }
    .campaign-prose ol > li::before { font-size: 1.5rem; top: 1.4rem; }
  }
</style>
