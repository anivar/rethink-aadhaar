---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroTitle from '~/components/HeroTitle.astro';
import Picture from '~/components/Picture.astro';
import { byDateDesc, groupByYear } from '~/lib/entries';
import { formatDate } from '~/lib/format';
import { renderMarkdown } from '~/lib/markdown';
import { itemList } from '~/lib/seo';

const page = await getEntry('page', 'press-coverage');
const data = page!.data;
const { Content } = await render(page!);

const all = (await getCollection('press')).sort(byDateDesc);
const byYear = groupByYear(all);
const years = [...byYear.keys()].sort((a, b) => b - a);
const firstYear = years.length ? years[years.length - 1] : null;

const description =
  'External press coverage of Aadhaar — exclusion stories, surveillance concerns, judgments and analysis.';
const jsonLd = itemList({
  name: 'Press coverage',
  url: '/press-coverage',
  items: all
    .slice(0, 25)
    .map((p) => ({ name: p.data.title, url: p.data.href, description: p.data.publication })),
});
---

<BaseLayout title="Press coverage" description={description} jsonLd={jsonLd}>
  <HeroTitle eyebrow="External coverage">{data.title}</HeroTitle>

  {data.intro && (
    <p class="container-prose mt-6 text-lg md:text-xl text-ink/80 font-body text-pretty fade-up">
      {data.intro}
    </p>
  )}

  {data.hero && (
    <figure class="container-prose mt-10 fade-up delay-1">
      <Picture src={data.hero} alt="" eager class="w-full h-auto" />
      {data.heroCaption && (
        <figcaption class="hero-caption" set:html={renderMarkdown(data.heroCaption)} />
      )}
    </figure>
  )}

  {/* Editorial body — month-by-month chronicle with inline links. */}
  <section class="container-prose mt-14 md:mt-20 fade-up">
    <article class="prose dark:prose-invert font-body text-pretty max-w-none">
      <Content />
    </article>
  </section>

  {/* Archive — earlier curated highlights from the press collection. */}
  {years.length > 0 && (
    <section class="container-prose mt-20 md:mt-28 mb-24 fade-up">
      <header class="mb-2">
        <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight">
          Selected coverage archive
        </h2>
        <p class="mt-3 caps text-xs text-ink/55 tracking-[0.18em]">
          {firstYear} · curated highlights
        </p>
      </header>

      {years.map((y) => (
        <section class="mt-12 md:mt-14">
          <header class="mb-4">
            <h3 class="font-display text-xl md:text-2xl font-extrabold tracking-tight">{y}</h3>
          </header>
          <ul class="divide-y divide-ink/15">
            {byYear.get(y)!.map((p) => (
              <li class="py-5 md:py-6">
                <a
                  href={p.data.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block hover:text-accent transition-colors"
                >
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                    <span class="caps text-[0.7rem] text-ink/55 tracking-[0.12em]">
                      {formatDate(p.data.date, 'monthYear')}
                    </span>
                    <span class="caps text-[0.68rem] bg-ink/[0.06] text-ink/75 px-2 py-0.5 tracking-[0.08em] group-hover:bg-accent/10 group-hover:text-accent transition-colors">
                      {p.data.publication}
                    </span>
                  </div>
                  <p class="font-display font-bold text-base md:text-lg leading-snug text-balance">
                    {p.data.title} <span class="text-accent inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">↗</span>
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}

      <p class="mt-16 text-sm text-ink/60">
        Looking for older coverage? Ram Krishnaswamy's <a class="underline hover:text-accent" href="https://aadhaar-articles.blogspot.in/" target="_blank" rel="noopener noreferrer">archive of UID-critical articles since 2010</a> is the most comprehensive index.
      </p>
    </section>
  )}
</BaseLayout>
