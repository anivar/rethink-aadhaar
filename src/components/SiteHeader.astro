---
import LogoMark from '~/components/LogoMark.astro';
import ThemeToggle from '~/components/ThemeToggle.astro';
import NavList from '~/components/header/NavList.astro';
import CompactNav from '~/components/header/CompactNav.astro';
import MobileNavSection from '~/components/header/MobileNavSection.astro';
import { link } from '~/lib/link';
import { NAV, DESKTOP_LEFT, DESKTOP_RIGHT } from '~/lib/navigation';

// Astro.url.pathname includes the configured `base` (e.g. /rethink-aadhaar/).
// Nav hrefs in src/lib/navigation.ts are stored base-less, so strip the
// prefix before string-matching — otherwise aria-current and .active never
// fire on production deploys.
const BASE = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const raw = Astro.url.pathname;
const stripped = BASE && raw.startsWith(BASE) ? raw.slice(BASE.length) : raw;
const path = stripped.replace(/\/$/, '') || '/';
const isHome = path === '/';
---

<header class="site-header">
  <!-- Three breakpoints share this top row.
       0–767  mobile  : logo + theme + hamburger     (flex)
       768–1023 compact: top row identical to mobile, compact nav drops below
       1024–1279 compact: compact nav inline beside logo (flex)
       1280+ full       : canonical 3-col split-nav  (xl:grid)               -->
  <div class="container-wide flex xl:grid xl:grid-cols-[1fr_auto_1fr] items-center justify-between gap-3 lg:gap-4 py-3 md:py-4 hdr-bar">

    <!-- LEFT NAV (full only, ≥1280) -->
    <nav class="hidden xl:flex xl:justify-end" aria-label="Primary (left)">
      <NavList items={DESKTOP_LEFT} ulClass="flex items-center gap-5 xl:gap-7" activePath={path} />
    </nav>

    <!-- LOGO — left-aligned at <xl, centred at xl+. The mark IS the home
         link on desktop, so add aria-current when on `/`. -->
    <a
      href={link('/')}
      class="xl:justify-self-center flex items-center group shrink-0"
      aria-label="Rethink Aadhaar — home"
      aria-current={isHome ? 'page' : undefined}
    >
      <LogoMark class="h-11 w-11 md:h-14 md:w-14 transition-transform group-hover:rotate-[-3deg]" />
      <span class="sr-only">Rethink Aadhaar</span>
    </a>

    <!-- RIGHT GROUP — grows to fill remaining width at md+ so children can
         right-justify. At xl+ it occupies the third grid column.            -->
    <div class="flex items-center gap-2 lg:gap-3 xl:gap-7 md:flex-1 md:justify-end xl:w-full">

      <!-- FULL right nav (xl+) -->
      <nav class="hidden xl:flex xl:flex-1 xl:justify-start" aria-label="Primary (right)">
        <NavList items={DESKTOP_RIGHT} ulClass="flex items-center gap-5 xl:gap-7" activePath={path} />
      </nav>

      <!-- COMPACT-INLINE nav (lg only, 1024–1279) -->
      <nav class="hidden lg:flex xl:hidden lg:flex-1 lg:justify-end items-center gap-4" aria-label="Compact">
        <CompactNav activePath={path} />
      </nav>

      <ThemeToggle />

      <button
        type="button"
        class="md:hidden hamburger inline-flex items-center justify-center w-11 h-11 border-2 border-ink/35 hover:border-accent active:bg-ink/10 active:scale-95 transition-all"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-toggle
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- COMPACT-STACK (768–1023): nav row drops below the logo bar -->
  <div class="hidden md:block lg:hidden border-t border-ink/10">
    <nav class="container-wide py-2 flex items-center gap-3" aria-label="Compact (row)">
      <CompactNav activePath={path} scrollable />
    </nav>
  </div>

  <!-- MOBILE PANEL (< md). Three named groups + a pinned CTA at the
       bottom. Sized via --hdr-h (set on :root per breakpoint in
       global.css) so the panel never overshoots the viewport. The
       inner div is the one that scrolls; the CTA stays pinned to the
       bottom via flex-col + flex-1 on the inner div. -->
  <div
    id="mobile-nav"
    class="md:hidden hidden mobile-nav-panel border-t border-ink/10 bg-bg flex flex-col"
    data-mobile-nav
  >
    <div class="mobile-nav-scroll flex-1 overflow-y-auto overscroll-contain">
      <nav class="container-wide py-4" aria-label="Mobile">
        <MobileNavSection id="m-primary" label="Primary"  items={NAV.primary}  activePath={path} />
        <MobileNavSection id="m-learn"   label="Learn"    items={NAV.learn}    activePath={path} />
        <MobileNavSection id="m-news"    label="Newsroom" items={NAV.newsroom} activePath={path} last />
      </nav>
    </div>
    <a
      href={link('/take-action')}
      class="btn-primary w-full justify-center text-sm py-4 mobile-cta"
      data-mobile-nav-link
    >Take action now →</a>
  </div>
</header>

<script>
  // Document-level listeners must register exactly once across the entire
  // page lifetime — re-binding on every astro:page-load would leak handlers.
  // Per-element bindings (toggle, drawer links) are guarded inside init()
  // via dataset markers; see #46.
  function initOnce() {
    const w = window as Window & { __rethinkHdrInit?: boolean };
    if (w.__rethinkHdrInit) return;
    w.__rethinkHdrInit = true;

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const panel = document.querySelector<HTMLElement>('[data-mobile-nav]');
      const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
      if (panel && !panel.classList.contains('hidden')) {
        panel.classList.add('hidden');
        btn?.setAttribute('aria-expanded', 'false');
        btn?.setAttribute('aria-label', 'Open menu');
        btn?.focus();
        return;
      }
      document.querySelectorAll<HTMLDetailsElement>('details[data-more]').forEach((d) => {
        if (d.open) {
          d.open = false;
          d.querySelector<HTMLElement>('summary')?.focus();
        }
      });
    });

    // "More ▾" closes when the user clicks anywhere outside it.
    document.addEventListener('click', (e) => {
      document.querySelectorAll<HTMLDetailsElement>('details[data-more]').forEach((d) => {
        if (d.open && !d.contains(e.target as Node)) d.open = false;
      });
    });
  }

  function init() {
    const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-mobile-nav]');
    if (!btn || !panel) return;
    if (btn.dataset.menuBound === 'true') return;
    btn.dataset.menuBound = 'true';

    function setOpen(open: boolean) {
      panel!.classList.toggle('hidden', !open);
      btn!.setAttribute('aria-expanded', String(open));
      btn!.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      // Minimal focus management: pull focus into the drawer on open and
      // hand it back to the toggle on close. Not a full Tab-cycling trap —
      // intentional, so users can still Shift-Tab back to the announcement
      // bar above the header.
      if (open) {
        panel!.querySelector<HTMLAnchorElement>('[data-mobile-nav-link]')?.focus();
      } else {
        btn!.focus();
      }
    }

    btn.addEventListener('click', () => {
      setOpen(panel.classList.contains('hidden'));
    });

    panel.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
  }

  initOnce();
  init();
  document.addEventListener('astro:page-load', init);
</script>
