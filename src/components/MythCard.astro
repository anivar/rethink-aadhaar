---
interface Props {
  myth: string;
  fact?: string;
  index: number;
  href?: string;
  summary?: boolean;
}
const { myth, fact, index, href, summary = false } = Astro.props;
const nn = String(index).padStart(2, '0');
---
<article
  class:list={[
    'group relative border-t-2 border-ink py-10 md:py-14 grid grid-cols-[2.75rem_minmax(0,1fr)] sm:grid-cols-[3.25rem_minmax(0,1fr)] md:grid-cols-[6rem_minmax(0,1fr)] gap-x-4 sm:gap-x-5 md:gap-x-10 gap-y-2 first:border-t-[3px]',
    href && 'myth-card',
  ]}
  id={`myth-${index}`}
>
  <div class="row-span-2 md:row-span-3 md:pt-2">
    <p class="font-display font-black text-4xl md:text-6xl leading-none text-accent select-none">{nn}</p>
  </div>

  <div>
    <p class="caps text-accent text-xs md:text-sm mb-2 md:mb-3">Myth</p>
    <p class="font-display font-bold text-xl sm:text-2xl md:text-3xl text-balance leading-snug">
      {href ? <a href={href} class="myth-card-link group-hover:text-accent transition-colors">{myth}</a> : myth}
    </p>
  </div>

  {fact && (
    <div class="col-start-2 mt-6 md:mt-8 border-l-2 border-accent/70 pl-4 md:pl-5">
      <p class="caps text-ink/55 text-xs md:text-sm mb-2 md:mb-3">Fact</p>
      <p class="font-display font-bold text-lg sm:text-xl md:text-2xl text-balance leading-snug">
        {fact}
      </p>
    </div>
  )}

  <div class="col-start-2 mt-6 md:mt-8">
    <div class:list={['prose font-body text-pretty', summary && 'myth-summary']}>
      <slot />
    </div>
    {href && (
      <p class="mt-6">
        <a class="myth-card-cta caps text-xs text-accent hover:underline" href={href}>Read more →</a>
      </p>
    )}
  </div>
</article>

<style is:global>
  /* Stretched-link pattern: the title anchor's ::before covers the whole
     card, so a click anywhere navigates to the detail page. CTA and any
     inline body links sit above the overlay so they stay independently
     clickable. Cursor follows the anchor naturally — no extra styling. */
  .myth-card-link::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .myth-card a:not(.myth-card-link) {
    position: relative;
    z-index: 2;
  }
</style>
