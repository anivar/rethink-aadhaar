---
// Server-rendered strip of the latest @no2uid posts. The cache is refreshed by
// .github/workflows/refresh-x.yml (cron, no admin work). Rendering happens
// at build time from src/data/x-feed.json — no Twitter SDK, no iframe, no
// theme conflicts. Historical posts accumulate in src/data/x-archive/.
import feed from '~/data/x-feed.json';

interface Props {
  handle?: string;
  /** How many cards to show. */
  limit?: number;
  class?: string;
}

const { handle = feed.handle ?? 'no2uid', limit = 6, class: cls = '' } = Astro.props;
const profileUrl = `https://twitter.com/${handle}`;
const posts = (feed.posts ?? []).slice(0, limit);

const fmt = (iso: string | null) =>
  iso ? new Date(iso).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : '';
---

<section class={`container-prose mt-20 md:mt-28 fade-up ${cls}`}>
  <div class="flex items-baseline justify-between gap-4 mb-6">
    <div>
      <p class="eyebrow mb-2">Live from the campaign</p>
      <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight">
        Latest from <a href={profileUrl} target="_blank" rel="noopener" class="hover:text-accent transition-colors">@{handle}</a>
      </h2>
    </div>
    <a
      href={profileUrl}
      target="_blank"
      rel="noopener"
      class="caps text-xs text-ink/70 hover:text-accent transition-colors hidden sm:inline"
    >Follow on X →</a>
  </div>

  {posts.length === 0 ? (
    <p class="text-base text-ink/70 font-body">
      Posts will appear here once the daily refresh runs.
      <a href={profileUrl} target="_blank" rel="noopener" class="underline hover:text-accent ml-1">Visit @{handle} on X →</a>
    </p>
  ) : (
    <ul class="grid sm:grid-cols-2 gap-4">
      {posts.map((p: any) => (
        <li class="card-surface p-5 flex flex-col gap-3">
          <div class="flex items-center justify-between text-xs text-ink/60 font-body">
            <span>{fmt(p.date)}</span>
            {p.isRetweet && <span class="caps tracking-[0.08em] text-accent">Retweet</span>}
          </div>
          <p class="font-body text-base text-pretty leading-snug">{p.text}</p>
          <a
            href={p.url}
            target="_blank"
            rel="noopener"
            class="caps text-[0.7rem] tracking-[0.08em] text-ink/70 hover:text-accent transition-colors mt-auto"
          >Open on X →</a>
        </li>
      ))}
    </ul>
  )}

  <p class="mt-6 text-xs text-ink/55 text-center sm:hidden">
    <a href={profileUrl} target="_blank" rel="noopener" class="caps tracking-[0.08em] hover:text-accent">Follow on X →</a>
  </p>
</section>
