---
// Static embed of the @no2uid X timeline. No admin work / no API key:
// the widget script (widgets.js) renders the timeline at view time and
// includes retweets natively. If the script is blocked, the inner <a>
// is the graceful fallback — a plain link to the profile.
interface Props {
  handle?: string;
  height?: number;
  /** Optional className passed to the wrapping section. */
  class?: string;
}
const { handle = 'no2uid', height = 700, class: cls = '' } = Astro.props;
const profileUrl = `https://twitter.com/${handle}`;
---

<section class={`container-prose mt-20 md:mt-28 fade-up ${cls}`} data-x-timeline>
  <div class="flex items-baseline justify-between gap-4 mb-6">
    <div>
      <p class="eyebrow mb-2">Live from the campaign</p>
      <h2 class="font-display text-2xl md:text-3xl font-extrabold tracking-tight">
        Latest from <a href={profileUrl} target="_blank" rel="noopener" class="hover:text-accent transition-colors">@{handle}</a>
      </h2>
    </div>
    <a
      href={profileUrl}
      target="_blank"
      rel="noopener"
      class="caps text-xs text-ink/70 hover:text-accent transition-colors hidden sm:inline"
    >Follow on X →</a>
  </div>

  <div class="card-surface p-3 md:p-4 max-w-2xl mx-auto">
    <a
      class="twitter-timeline"
      data-height={height}
      data-chrome="noheader nofooter transparent"
      data-dnt="true"
      data-theme="light"
      href={`${profileUrl}?ref_src=twsrc%5Etfw`}
    >
      Posts by @{handle}
    </a>
  </div>

  <p class="mt-4 text-xs text-ink/55 text-center sm:hidden">
    <a href={profileUrl} target="_blank" rel="noopener" class="caps tracking-[0.08em] hover:text-accent">Follow on X →</a>
  </p>
</section>

<script is:inline>
  // Match the X widget theme to the site mode, then load widgets.js once.
  (function () {
    var setTheme = function () {
      var dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.twitter-timeline').forEach(function (el) {
        el.setAttribute('data-theme', dark ? 'dark' : 'light');
      });
    };
    setTheme();

    if (!document.getElementById('twitter-wjs')) {
      var s = document.createElement('script');
      s.id = 'twitter-wjs';
      s.async = true;
      s.src = 'https://platform.twitter.com/widgets.js';
      document.body.appendChild(s);
    } else if (window.twttr && window.twttr.widgets) {
      window.twttr.widgets.load();
    }

    // Re-render the timeline after a theme toggle so the iframe matches.
    var mo = new MutationObserver(function () {
      setTheme();
      if (window.twttr && window.twttr.widgets) {
        document.querySelectorAll('[data-x-timeline] .twitter-timeline-rendered').forEach(function (el) { el.remove(); });
        window.twttr.widgets.load();
      }
    });
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  })();
</script>
