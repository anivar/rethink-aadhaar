---
interface Props {
  question: string;
  short?: string;
  index: number;
  href?: string;
  summary?: boolean;
}
const { question, short, index, href, summary = false } = Astro.props;
const nn = String(index).padStart(2, '0');
---
<article class="py-10 md:py-14 border-t border-ink/15 first:border-t-0" id={`faq-${index}`}>
  <div class="grid grid-cols-[2.25rem_minmax(0,1fr)] sm:grid-cols-[2.5rem_minmax(0,1fr)] md:grid-cols-[4rem_minmax(0,1fr)] gap-x-3 sm:gap-x-4 md:gap-x-8 gap-y-4">
    <p class="caps text-accent text-sm md:text-base font-bold tracking-[0.08em] pt-1 md:pt-2">
      {href ? <a href={href} class="hover:underline">Q{nn}</a> : <>Q{nn}</>}
    </p>
    <h3 class="faq-question font-display font-extrabold text-xl sm:text-2xl md:text-[1.85rem] text-balance leading-snug">
      {href ? <a href={href} class="hover:text-accent transition-colors">{question}</a> : question}
    </h3>

    {short && (
      <p class="col-start-2 -mt-1 text-base md:text-lg font-body text-ink/75 italic text-pretty">
        {short}
      </p>
    )}

    <div class:list={['col-start-2 mt-2 md:mt-4 faq-answer prose font-body text-pretty', summary && 'faq-summary']}>
      <slot />
    </div>

    {href && (
      <p class="col-start-2 mt-2">
        <a class="caps text-xs text-accent hover:underline" href={href}>Read full answer →</a>
      </p>
    )}
  </div>
</article>

<style is:global>
  /* Summary mode on /faqs listing: show only the first paragraph from the
     source body, hide everything after it. The full content lives on
     /faqs/<slug>/. */
  .faq-summary > * + * { display: none; }
</style>
