---
interface Props { question: string; }
const { question } = Astro.props;
---
<article class="py-8 border-t border-ink/15 first:border-t-0">
  <h3 class="faq-question font-display font-bold text-2xl md:text-3xl text-balance leading-snug mb-5">
    <span class="text-accent mr-3" aria-hidden="true">→</span>{question}
  </h3>
  <div class="faq-answer prose font-body text-pretty">
    <slot />
  </div>
</article>
