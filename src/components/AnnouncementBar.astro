---
import { link } from '~/lib/link';
// Dark campaign bar above the header. Non-dismissible — matches the
// original rethinkaadhaar.in template, where the call to action is
// always visible.
---

<div class="announcement-bar bg-button text-white">
  <div class="container-wide py-2">
    <p class="caps text-[0.7rem] sm:text-xs text-center">
      Rethink Aadhaar.
      <span class="hidden sm:inline">Opt-out from Aadhaar.</span>
      <a href={link('/take-action')} class="underline underline-offset-2 hover:text-accent">Take action now →</a>
    </p>
  </div>
</div>
