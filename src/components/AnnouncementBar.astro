---
import { link } from '~/lib/link';
// Black bar above the header, dismissible (localStorage flag).
---

<div id="rta-banner" class="bg-button text-white" data-banner>
  <div class="container-wide flex items-center justify-between gap-4 py-2">
    <p class="caps text-[0.7rem] sm:text-xs">
      Rethink Aadhaar.
      <span class="hidden sm:inline">Opt-out from Aadhaar.</span>
      <a href={link('/take-action')} class="underline underline-offset-2 hover:text-accent">Take action now →</a>
    </p>
    <button
      type="button"
      aria-label="Dismiss announcement"
      data-dismiss
      class="w-7 h-7 inline-flex items-center justify-center text-base hover:text-accent transition-colors"
    >
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>
</div>

<script>
  const KEY = 'rta-banner-dismissed-1';
  function init() {
    const el = document.querySelector<HTMLElement>('[data-banner]');
    if (!el) return;
    if (localStorage.getItem(KEY) === '1') { el.style.display = 'none'; return; }
    el.querySelector<HTMLButtonElement>('[data-dismiss]')?.addEventListener('click', () => {
      localStorage.setItem(KEY, '1');
      el.style.display = 'none';
    });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
