---
const year = new Date().getFullYear();
const RAYS = 60;
const cx = 600, cy = 400;
const rays = Array.from({ length: RAYS }, (_, i) => {
  const t = i / (RAYS - 1);
  const angle = ((-180 + t * 180) * Math.PI) / 180;
  const len = 900 + Math.sin(t * Math.PI) * 220;
  return { x2: cx + Math.cos(angle) * len, y2: cy + Math.sin(angle) * len, w: 1 + (i % 5 === 0 ? 1.2 : 0) };
});
---

<footer class="mt-24">
  <div class="container-prose pb-10">
    <p class="font-body text-base text-ink/85 leading-relaxed">
      <a class="underline underline-offset-2" href="/about">About</a>
      <span aria-hidden="true"> | </span>
      <a class="underline underline-offset-2" href="mailto:contact@rethinkaadhaar.in">Email</a>
      <span aria-hidden="true"> | </span>
      <a class="underline underline-offset-2" href="https://twitter.com/no2uid" rel="me noopener">Twitter</a>
      <span aria-hidden="true"> | </span>
      <a class="underline underline-offset-2" href="https://www.facebook.com/no2uid/" rel="me noopener">Facebook</a>
      <span aria-hidden="true"> | </span>
      <span>All original content is shared under <a class="underline underline-offset-2" href="https://creativecommons.org/licenses/by/4.0/" rel="license noopener">CC BY 4.0</a> International license.</span>
    </p>
  </div>

  <div class="relative w-full overflow-hidden bg-[#0E0E0E]">
    <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMax slice" class="block w-full h-[260px] md:h-[340px]" aria-hidden="true">
      <rect width="1200" height="400" fill="#0E0E0E"/>
      <g stroke="#FFFFFF" stroke-linecap="square" opacity="0.95">
        {rays.map((r) => <line x1={cx} y1={cy} x2={r.x2} y2={r.y2} stroke-width={r.w} />)}
      </g>
      <circle cx={cx} cy={cy} r="14" fill="#0E0E0E"/>
    </svg>
    <p class="absolute inset-x-0 bottom-3 text-center text-xs text-white/70 caps">
      © {year} Rethink Aadhaar · CC BY 4.0 · Built with Astro
    </p>
  </div>
</footer>
