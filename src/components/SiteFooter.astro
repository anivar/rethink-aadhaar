---
import LogoMark from '~/components/LogoMark.astro';
import { link } from '~/lib/link';
const year = new Date().getFullYear();

// Black starburst — 60 rays sweeping -180° to 0°, woodblock-style mark
// matching the canonical rethinkaadhaar.in footer image.
const RAYS = 60;
const cx = 600,
  cy = 400;
const rays = Array.from({ length: RAYS }, (_, i) => {
  const t = i / (RAYS - 1);
  const angle = ((-180 + t * 180) * Math.PI) / 180;
  const len = 900 + Math.sin(t * Math.PI) * 220;
  return {
    x2: cx + Math.cos(angle) * len,
    y2: cy + Math.sin(angle) * len,
    w: 1 + (i % 5 === 0 ? 1.2 : 0),
  };
});
---

<footer class="mt-24 border-t border-ink/10 bg-bg">
  <div class="container-wide py-10 md:py-16 grid gap-8 sm:gap-10 sm:grid-cols-2 md:grid-cols-[2fr_1fr_1fr_1.2fr] items-start">
    <div>
      <div class="flex items-center gap-3">
        <LogoMark class="h-10 w-10" />
        <p class="font-display text-2xl uppercase tracking-tight leading-tight">Rethink<br/>Aadhaar</p>
      </div>
      <p class="mt-5 font-body text-base text-ink/80 max-w-md leading-relaxed">
        A coalition of citizens, researchers, and lawyers documenting Aadhaar's effects on welfare, privacy, and democratic practice.
      </p>
    </div>

    <nav aria-label="Footer">
      <p class="caps text-xs text-ink/60 mb-3">Site</p>
      <ul class="space-y-2 font-body">
        <li><a class="hover:text-accent" href={link('/about')}>About</a></li>
        <li><a class="hover:text-accent" href={link('/take-action')}>Take action</a></li>
        <li><a class="hover:text-accent" href={link('/resources')}>Resources</a></li>
        <li><a class="hover:text-accent inline-flex items-center gap-2" href={link('/rss.xml')} aria-label="Updates feed (RSS)">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M3.75 3a.75.75 0 0 0-.75.75v1.5c0 .414.336.75.75.75 8.25 0 15 6.75 15 15 0 .414.336.75.75.75h1.5a.75.75 0 0 0 .75-.75C21.75 12 12.75 3 3.75 3Zm0 6a.75.75 0 0 0-.75.75v1.5c0 .414.336.75.75.75A8.25 8.25 0 0 1 12 20.25c0 .414.336.75.75.75h1.5a.75.75 0 0 0 .75-.75A11.25 11.25 0 0 0 3.75 9ZM6 16.5A1.5 1.5 0 1 0 6 19.5a1.5 1.5 0 0 0 0-3Z"/></svg>
          Feed
        </a></li>
        <li><a class="hover:text-accent" href={link('/sitemap-index.xml')}>Sitemap</a></li>
        <li><a class="hover:text-accent" href={link('/llms.txt')}>llms.txt</a></li>
      </ul>
    </nav>

    <div>
      <p class="caps text-xs text-ink/60 mb-3">Connect</p>
      <ul class="space-y-2 font-body">
        <li>
          <a class="hover:text-accent inline-flex items-center gap-2" href="mailto:contact@rethinkaadhaar.in">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
            Email
          </a>
        </li>
        <li>
          <a class="hover:text-accent inline-flex items-center gap-2" href="https://twitter.com/no2uid" rel="me noopener noreferrer">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21.5l-7.5 8.572L23 22h-6.844l-5.36-7.014L4.61 22H1.35l8.026-9.176L1 2h7.018l4.846 6.41L18.244 2Zm-1.2 18h1.86L7.06 4H5.067l11.977 16Z"/></svg>
            Twitter / X
          </a>
        </li>
        <li>
          <a class="hover:text-accent inline-flex items-center gap-2" href="https://www.facebook.com/no2uid/" rel="me noopener noreferrer">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true"><path d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07c0 5.02 3.66 9.18 8.44 9.93v-7.02H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.45 2.91h-2.33V22c4.78-.75 8.43-4.91 8.43-9.93Z"/></svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>

    <div>
      <p class="caps text-xs text-ink/60 mb-3">Mailing list</p>
      <p class="font-body text-sm text-ink/75 mb-3 leading-relaxed">
        Low-traffic updates. Hosted on Riseup; you'll get a confirmation email.
      </p>
      <form
        action="https://lists.riseup.net/www/subscribe/rethink-aadhaar"
        method="post"
        class="flex flex-col gap-2"
      >
        <label class="sr-only" for="footer-subscribe-email">Email address</label>
        <input
          id="footer-subscribe-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.org"
          class="font-body text-sm px-3 py-2.5 bg-surface border border-ink/25 focus:border-accent outline-none w-full"
        />
        <button type="submit" class="caps text-xs px-4 py-2.5 bg-button text-white border-l-4 border-accent hover:bg-accent transition-colors">
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Canonical-style starburst band — black with white rays sweeping -180° to 0°. -->
  <div class="relative w-full overflow-hidden bg-[#0E0E0E]">
    <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMax slice" class="block w-full h-[140px] sm:h-[180px] md:h-[300px]" aria-hidden="true">
      <rect width="1200" height="400" fill="#0E0E0E"/>
      <g stroke="#FFFFFF" stroke-linecap="square" opacity="0.95">
        {rays.map((r) => <line x1={cx} y1={cy} x2={r.x2} y2={r.y2} stroke-width={r.w} />)}
      </g>
      <circle cx={cx} cy={cy} r="14" fill="#0E0E0E"/>
    </svg>
    <p class="absolute inset-x-0 bottom-3 px-4 text-center text-[0.65rem] sm:text-xs text-white/80 caps leading-relaxed text-balance">
      © {year} Rethink Aadhaar · CC BY 4.0 · Built with Astro by <a href="https://anivar.net" rel="author noopener noreferrer" class="underline hover:text-white">anivar</a> · Hosted on GitHub Pages
    </p>
  </div>
</footer>
