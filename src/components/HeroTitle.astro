---
/**
 * Page header lockup: optional eyebrow, optional rule, h1.
 *
 * Two variants:
 *  - `page` (default) — h1 inherits the base type scale (`--text-h1`).
 *    Used by every interior page. No rule by default; eyebrow goes above.
 *  - `display` — h1 uses the `hero-display` utility (`--text-display`,
 *    Fraunces ExtraBold, full-bleed). Reserved for the homepage hero —
 *    Fraunces 800 at display size has wider glyph metrics than Inter and
 *    overflows narrow viewports for any title >1 word, so don't reach for
 *    it elsewhere.
 */
interface Props {
  eyebrow?: string;
  class?: string;
  rule?: boolean;
  align?: 'center' | 'left';
  variant?: 'display' | 'page';
}
// biome-ignore format: prop list reads as a vertical signature
const {
  eyebrow,
  class: cls = '',
  rule,
  align = 'center',
  variant = 'page',
} = Astro.props;
const alignCls = align === 'center' ? 'text-center' : 'text-left';
const showRule = rule ?? variant === 'display';
const h1Cls = variant === 'display' ? 'hero-title' : '';
---
<header class={`container-prose pt-10 sm:pt-14 md:pt-20 fade-up ${alignCls} ${cls}`}>
  {showRule && <div class={`hero-rule ${align === 'left' ? '!ml-0' : ''}`} aria-hidden="true"></div>}
  {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
  <h1 class={`${h1Cls} text-balance`.trim()}><slot /></h1>
</header>
