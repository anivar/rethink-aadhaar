---
// Image-thumbnail grid for poster sections of /resources. Same data shape as
// ResourceList but renders the `image` field as a clickable thumbnail; the
// click target is the original full-resolution asset (download attribute set
// so browsers save rather than open inline).
//
// scripts/optimize-images.ts emits a .webp sibling for every JPG/PNG under
// public/media/ at build time, so we serve .webp to browsers that accept it
// and fall back to the original for download. Originals stay full-resolution.

interface Item {
  title: string;
  href: string;
  image?: string;
  description?: string;
  order?: number;
}
interface Props {
  section: string;
  id?: string;
  items: Item[];
}
const { section, id, items } = Astro.props;
const sorted = [...items].filter((i) => i.image).sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const webpOf = (path: string) => path.replace(/\.(jpe?g|png)$/i, '.webp');
const downloadName = (path: string) => decodeURIComponent(path.split('/').pop() ?? '');
---
<section class="py-12 md:py-16 border-t border-ink/15 first:border-t-0" id={id}>
  <header class="mb-6 md:mb-8">
    <h2 class="caps text-accent text-sm md:text-base tracking-[0.12em]">{section}</h2>
  </header>

  <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-6">
    {sorted.map((item) => (
      <li>
        <a
          href={item.href}
          download={downloadName(item.href)}
          class="group block card-surface p-3 hover:border-accent/60 transition-colors"
          title={`Download ${item.title}`}
        >
          <picture>
            <source type="image/webp" srcset={webpOf(item.image!)} />
            <img
              src={item.image}
              alt={item.title}
              loading="lazy"
              decoding="async"
              class="w-full h-auto aspect-[3/4] object-contain bg-ink/5"
            />
          </picture>
          <p class="mt-3 font-body text-xs md:text-sm text-ink/80 leading-snug text-pretty group-hover:text-accent transition-colors">
            {item.title}
            <span class="text-accent" aria-hidden="true"> ↓</span>
          </p>
        </a>
      </li>
    ))}
  </ul>
</section>
