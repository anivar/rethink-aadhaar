---
interface Props { class?: string }
const { class: cls = '' } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class={cls} role="img" aria-label="Rethink Aadhaar mark">
  <rect width="64" height="64" fill="#D62636"/>
  <g fill="#FFFFFF">
    <!-- outer eye/sun -->
    <ellipse cx="32" cy="32" rx="22" ry="14" fill="none" stroke="#FFFFFF" stroke-width="3"/>
    <!-- iris -->
    <circle cx="32" cy="32" r="8.5" fill="#FFFFFF"/>
    <circle cx="32" cy="32" r="3.5" fill="#D62636"/>
    <!-- rays -->
    <g stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round">
      <line x1="32" y1="6"  x2="32" y2="11"/>
      <line x1="32" y1="53" x2="32" y2="58"/>
      <line x1="6"  y1="32" x2="11" y2="32"/>
      <line x1="53" y1="32" x2="58" y2="32"/>
      <line x1="13" y1="13" x2="17" y2="17"/>
      <line x1="47" y1="47" x2="51" y2="51"/>
      <line x1="51" y1="13" x2="47" y2="17"/>
      <line x1="17" y1="47" x2="13" y2="51"/>
    </g>
  </g>
</svg>
