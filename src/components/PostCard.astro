---
import { formatDate } from '~/lib/format';
import Picture from '~/components/Picture.astro';
interface Props {
  href: string;
  title: string;
  date: Date;
  excerpt?: string;
  hero?: string;
}
const { href, title, date, excerpt, hero } = Astro.props;
---
<article class="group relative flex flex-col h-full card-surface hover:border-accent focus-within:border-accent hover:shadow-[0_8px_24px_-12px_rgba(215,40,47,0.25)] transition-all duration-200">
  {hero && (
    <div class="block aspect-[16/10] overflow-hidden bg-ink/5">
      <Picture src={hero} alt="" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out" />
    </div>
  )}
  <div class="p-5 md:p-6 flex flex-col flex-1">
    <p class="eyebrow mb-3">{formatDate(date, 'medium')}</p>
    <h3 class="font-display font-bold text-lg md:text-xl leading-snug text-balance mb-3">
      {/* Stretched link: ::before covers the whole card so the entire
         article is clickable, while screen readers still see one anchor. */}
      <a
        href={href}
        class="group-hover:text-accent transition-colors before:content-[''] before:absolute before:inset-0 focus-visible:outline-none"
      >{title}</a>
    </h3>
    {excerpt && <p class="font-body text-base text-ink/80 leading-relaxed text-pretty line-clamp-4">{excerpt}</p>}
    <span class="caps text-xs mt-auto pt-4 text-accent inline-flex items-center gap-1.5" aria-hidden="true">
      Read
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </span>
  </div>
</article>
