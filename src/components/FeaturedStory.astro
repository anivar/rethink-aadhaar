---
import { formatDate } from '~/lib/format';
interface Props { href: string; title: string; date?: Date; }
const { href, title, date } = Astro.props;
const dateStr = date ? formatDate(date, 'medium') : null;
---
<aside class="surface-paper my-16 md:my-24">
  <div class="container-prose py-12 md:py-16 grid md:grid-cols-[auto_1fr] items-start gap-6 md:gap-10">
    <p class="caps text-accent text-xs">Featured</p>
    <div>
      <h2 class="font-display font-bold text-2xl md:text-4xl text-balance leading-snug mb-4">
        <a href={href} class="hover:text-accent transition-colors">{title}</a>
      </h2>
      {dateStr && <p class="caps text-xs text-ink/60 mb-5">{dateStr}</p>}
      <div class="prose font-body text-pretty">
        <slot />
      </div>
      <p class="mt-6"><a href={href} class="caps text-xs text-accent inline-flex items-center gap-1 group">
        Read full story <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </a></p>
    </div>
  </div>
</aside>
