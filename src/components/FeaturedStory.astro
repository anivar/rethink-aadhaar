---
import { formatDate } from '~/lib/format';
interface Props {
  href: string;
  title: string;
  date?: Date;
}
const { href, title, date } = Astro.props;
const dateStr = date ? formatDate(date, 'medium') : null;
---
<aside class="my-16 md:my-24 fade-up">
  <div class="container-prose">
    <div class="featured-card surface-paper border-l-4 md:border-l-[6px] border-accent p-7 md:p-12 grid md:grid-cols-[auto_1fr] items-start gap-x-10 gap-y-5">
      <div class="featured-flag">
        <span class="featured-pill">★ Featured</span>
      </div>
      <div>
        <h2 class="font-display font-extrabold text-2xl md:text-4xl text-balance leading-snug mb-3 tracking-tight">
          <a href={href} class="hover:text-accent transition-colors">{title}</a>
        </h2>
        {dateStr && <p class="caps text-xs text-ink/60 mb-5">{dateStr}</p>}
        <div class="prose font-body text-pretty text-base md:text-lg">
          <slot />
        </div>
        <p class="mt-6">
          <a href={href} class="caps text-xs text-accent inline-flex items-center gap-1.5 group font-bold tracking-[0.08em]">
            Read full story
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </p>
      </div>
    </div>
  </div>
</aside>

<style>
  .featured-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 0.85rem;
    line-height: 1;
    white-space: nowrap;
  }
  .featured-flag { padding-top: 0.25rem; }
</style>
